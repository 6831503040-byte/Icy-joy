{
  "entities": {
    "IceCream": {
      "title": "IceCream",
      "description": "Ice cream product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string", "enum": ["Classic", "Special", "Fruity"] },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "color": { "type": "string" }
      },
      "required": ["id", "name", "price", "rating", "reviewCount"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review and rating",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["productId", "userId", "rating", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "points": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "IceCream",
      "description": "Collection of ice cream products"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of product reviews"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
